generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  username          String?   @unique
  bio               String?
  profileIsPublic   Boolean   @default(false)
  preferredLanguage String    @default("hu")
  theme             String    @default("black-white")
  emailVerified     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  scooters    Scooter[]
  sessions    Session[]
  accounts    Account[]
  saleReports SaleReport[]

  @@map("user")
}

model Scooter {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand           String
  model           String
  color           String?
  serialNumber    String?
  year            Int?
  purchaseDate    DateTime?
  purchasePrice   Int?
  currentMileage  Int       @default(0)
  batteryCapacity Int?
  topSpeed        Int?
  rangeKm         Int?
  photoUrl        String?
  notes           String?
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  valueEstimates ValueEstimate[]
  services       Service[]
  rides          Ride[]
  saleReport     SaleReport?
  condition      ScooterCondition?

  @@index([userId])
}

// Megosztható, visszavonható "Eladási állapotlap" link. Rollerenként
// legfeljebb egy sor (unique scooterId): (re)aktiváláskor a meglévő sor
// tokenje mindig lecserélődik, így egy visszavont token soha nem válik
// újra érvényessé, még ugyanannak a rollernek az újbóli megosztásakor sem.
// A publikus oldal a `snapshot` mezőben tárolt, validált, publikálás
// pillanatában rögzített adatból épül fel (nem élő rollerből) — a
// `snapshotHash` a snapshot tartalmának determinisztikus lenyomata, ami
// alapján az élő adatokból újraépített előnézet összevethető a jelenleg
// publikus tartalommal. A `snapshot` induláskor nullable, hogy a mezőt már
// meglévő aktív sorokra is additívan rá lehessen vezetni (lásd a legacy
// migrációs viselkedést a sale-report szolgáltatásban).
model SaleReport {
  id          String  @id @default(cuid())
  scooterId   String  @unique
  scooter     Scooter @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  publicToken String  @unique
  isActive    Boolean @default(true)

  snapshot        Json?
  snapshotHash    String?
  snapshotVersion Int       @default(1)
  publishedAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?

  @@index([ownerId])
}

enum ConditionLevel {
  GOOD
  FAIR
  NEEDS_ATTENTION
}

enum KnownIssuesState {
  NOT_PROVIDED
  NONE_REPORTED
  REPORTED
}

// A tulajdonos saját, szöveges állapotfelmérése (nem hivatalos műszaki
// vizsgálat). Nincs külön `ownerId` mező: a jogosultság mindig a Scooter
// relációján keresztül, `scooter.userId`-n át ellenőrzendő, hogy ne legyen
// egy második, önállóan elszállható owner-konzisztencia probléma.
model ScooterCondition {
  id        String  @id @default(cuid())
  scooterId String  @unique
  scooter   Scooter @relation(fields: [scooterId], references: [id], onDelete: Cascade)

  overall          ConditionLevel?
  battery          ConditionLevel?
  brakes           ConditionLevel?
  tires            ConditionLevel?
  lights           ConditionLevel?
  frame            ConditionLevel?
  cosmetics        ConditionLevel?
  knownIssuesState KnownIssuesState @default(NOT_PROVIDED)
  knownIssues      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ServiceType {
  TIRE_CHANGE
  BRAKE_CHANGE
  BATTERY
  SERVICE
  OTHER
}

model Service {
  id          String      @id @default(cuid())
  scooterId   String
  scooter     Scooter     @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  type        ServiceType
  performedAt DateTime
  odometerKm  Int?
  cost        Int?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  deletedAt   DateTime?

  @@index([scooterId])
}

model Ride {
  id         String    @id @default(cuid())
  scooterId  String
  scooter    Scooter   @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  startAt    DateTime
  endAt      DateTime?
  distanceKm Float?
  avgSpeed   Float?
  maxSpeed   Float?
  createdAt  DateTime  @default(now())

  @@index([scooterId])
}

model ValueEstimate {
  id               String   @id @default(cuid())
  scooterId        String
  scooter          Scooter  @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  estimatedValue   Int
  algorithmVersion String
  createdAt        DateTime @default(now())

  @@index([scooterId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
