
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  username          String?   @unique
  bio               String?
  profileIsPublic   Boolean   @default(false)
  preferredLanguage String    @default("hu")
  theme             String    @default("black-white")
  emailVerified     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  scooters    Scooter[]
  sessions    Session[]
  accounts    Account[]
  saleReports SaleReport[]

  @@map("user")
}

model Scooter {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand           String
  model           String
  color           String?
  serialNumber    String?
  year            Int?
  purchaseDate    DateTime?
  purchasePrice   Int?
  currentMileage  Int       @default(0)
  batteryCapacity Int?
  topSpeed        Int?
  rangeKm         Int?
  photoUrl        String?
  notes           String?
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  valueEstimates ValueEstimate[]
  services       Service[]
  rides          Ride[]
  saleReport     SaleReport?

  @@index([userId])
}

// Megosztható, visszavonható "Eladási állapotlap" link. Rollerenként
// legfeljebb egy sor (unique scooterId): (re)aktiváláskor a meglévő sor
// tokenje mindig lecserélődik, így egy visszavont token soha nem válik
// újra érvényessé, még ugyanannak a rollernek az újbóli megosztásakor sem.
// A publikus oldal mindig élő roller/szerviz/becslés adatból épül; az
// `updatedAt` csak tudatos tulajdonosi művelet (létrehozás/frissítés/
// visszavonás) után változik, nem a roller adatainak módosításakor.
model SaleReport {
  id          String    @id @default(cuid())
  scooterId   String    @unique
  scooter     Scooter   @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  publicToken String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  revokedAt   DateTime?

  @@index([ownerId])
}

enum ServiceType {
  TIRE_CHANGE
  BRAKE_CHANGE
  BATTERY
  SERVICE
  OTHER
}

model Service {
  id          String      @id @default(cuid())
  scooterId   String
  scooter     Scooter     @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  type        ServiceType
  performedAt DateTime
  odometerKm  Int?
  cost        Int?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  deletedAt   DateTime?

  @@index([scooterId])
}

model Ride {
  id         String    @id @default(cuid())
  scooterId  String
  scooter    Scooter   @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  startAt    DateTime
  endAt      DateTime?
  distanceKm Float?
  avgSpeed   Float?
  maxSpeed   Float?
  createdAt  DateTime  @default(now())

  @@index([scooterId])
}

model ValueEstimate {
  id               String   @id @default(cuid())
  scooterId        String
  scooter          Scooter  @relation(fields: [scooterId], references: [id], onDelete: Cascade)
  estimatedValue   Int
  algorithmVersion String
  createdAt        DateTime @default(now())

  @@index([scooterId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
